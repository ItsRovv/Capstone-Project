PORT=5000

# --- Database: Supabase (Postgres) ---
# Recommended: paste the full connection string from
# Supabase → Project Settings → Database → Connection string → "URI".
# Use the connection POOLER URI (port 6543) for long-lived / serverless apps.
# Example: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# SSL is required by Supabase. Leave as true (auto-enabled when DATABASE_URL is set).
DB_SSL=true

# Alternatively, set discrete vars for a LOCAL Postgres (DATABASE_URL takes priority):
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=postgres

# --- AI Providers ---
# Primary: Anthropic Claude (optional — if missing, falls back to free AI then local)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Free AI fallback: gemini or groq (set one of the keys below)
FREE_AI_PROVIDER=gemini
# Google Gemini — get a key at https://aistudio.google.com/app/apikey (no credit card)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Groq — get a key at https://console.groq.com/keys (no credit card, 30 RPM free)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Force offline local AI (rule-based, no API keys). Set to true to skip all cloud providers.
USE_LOCAL_AI=false

JWT_SECRET=replace-with-a-long-random-string

# --- n8n / external automation ---
# A long random secret shared between the API and n8n. n8n sends this in the
# x-automation-token header to trigger protected endpoints without logging in.
AUTOMATION_TOKEN=replace-with-a-long-random-string-for-n8n
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Automatic daily report (optional) ---
# Cron expression for end-of-day report generation (server local time). Default 18:00 daily.
REPORT_CRON=0 18 * * *
# Where to email the generated report. Leave blank to only store it in the DB.
REPORT_EMAIL=

# --- Email (SMTP) — used for OTP codes (password reset + account verification) ---
# Gmail setup:
#   1. Enable 2-Step Verification on the Gmail account.
#   2. Create an App Password: https://myaccount.google.com/apppasswords
#   3. Put the 16-character app password (no spaces) in SMTP_PASSWORD below.
# If left blank, email is skipped and new accounts are auto-verified (dev-friendly).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail-address@gmail.com
SMTP_PASSWORD=your-16-char-app-password
SMTP_FROM="Jean Lying-in Maternity Clinic <your-gmail-address@gmail.com>"

# --- OTP settings (optional) ---
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
