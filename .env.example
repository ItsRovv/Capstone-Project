PORT=5000
DB_HOST=db
DB_PORT=3306
DB_USER=clinic
DB_PASSWORD=clinic_pass_change_me
DB_NAME=lying_in_clinic
JWT_SECRET=replace-with-a-long-random-string
# Set this to the exact origin(s) that serve the frontend. Do NOT use "*" —
# credentialed CORS requests are rejected by browsers when the origin is a wildcard.
# In single-container production (API serves the built SPA) same-origin needs no CORS.
CORS_ORIGIN=http://localhost:5000
# --- AI Providers ---
# Primary: Anthropic Claude (optional — if missing, falls back to free AI then local)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Free AI fallback: gemini or groq (set one of the keys below)
FREE_AI_PROVIDER=gemini
# Google Gemini — get a key at https://aistudio.google.com/app/apikey (no credit card)
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
# Groq — get a key at https://console.groq.com/keys (no credit card, 30 RPM free)
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.3-70b-versatile

# Force offline local AI (rule-based, no API keys). Set to true to skip all cloud providers.
USE_LOCAL_AI=false

NODE_ENV=production

# --- Automatic daily report (optional) ---
# Cron expression for end-of-day report generation (server local time). Default 18:00 daily.
REPORT_CRON=0 18 * * *
# Where to email the generated report. Leave blank to only store it in the DB.
REPORT_EMAIL=
# SMTP settings for sending the report email (all optional; if unset, email is skipped).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lying-In Clinic <no-reply@clinic.local>"
