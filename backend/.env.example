PORT=5000
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=lying_in_clinic
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash
JWT_SECRET=replace-with-a-long-random-string
CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# --- Automatic daily report (optional) ---
# Cron expression for end-of-day report generation (server local time). Default 18:00 daily.
REPORT_CRON=0 18 * * *
# Where to email the generated report. Leave blank to only store it in the DB.
REPORT_EMAIL=
# SMTP settings for sending the report email (all optional; if unset, email is skipped).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Lying-In Clinic <no-reply@clinic.local>"
