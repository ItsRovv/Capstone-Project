{
  "name": "Daily Clinic Report",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours"
            }
          ]
        }
      },
      "id": "schedule-node",
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [250, 300],
      "cron": {
        "expression": "0 18 * * *"
      }
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ $env.CLINIC_API_URL }}/api/automation/daily-report",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-automation-token",
              "value": "={{ $env.CLINIC_AUTOMATION_TOKEN }}"
            }
          ]
        }
      },
      "id": "http-node",
      "name": "Call Clinic API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [450, 300]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Call Clinic API",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  },
  "staticData": null,
  "tags": [
    {
      "name": "clinic",
      "id": "tag-clinic"
    }
  ]
}
