# n8n Docker Compose environment
#
# Copy this to .env and fill in the values.

# --- n8n UI access ---
N8N_HOST=n8n.yourclinic.com
N8N_PROTOCOL=https
WEBHOOK_URL=https://n8n.yourclinic.com/

# Basic auth for the n8n web editor
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password-immediately

# Long random string (e.g. openssl rand -hex 32)
N8N_ENCRYPTION_KEY=change-this-to-a-long-random-string

# Timezone for cron nodes
GENERIC_TIMEZONE=Asia/Manila

# --- Clinic API connection ---
CLINIC_API_URL=https://your-do-api-url.ondigitalocean.app
CLINIC_AUTOMATION_TOKEN=change-this-token-to-a-long-random-string

# --- Optional: use your Supabase Postgres as n8n's own DB instead of SQLite ---
# N8N_DB_TYPE=postgresdb
# N8N_DB_HOST=aws-0-xxxxx.pooler.supabase.com
# N8N_DB_PORT=6543
# N8N_DB_NAME=postgres
# N8N_DB_USER=postgres.your-project-ref
# N8N_DB_PASSWORD=your-supabase-db-password
# N8N_DB_SSL=true
